# Turso database (create separate dev + prod databases)
DATABASE_URL=libsql://your-database-name-your-org.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Admin shared password for /admin/login
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session encryption secret (minimum 32 characters)
SESSION_SECRET=change-me-to-a-random-32-character-secret

# WhatsApp booking number is configured in src/data/site.ts
